# ─────────────────────────────────────────────────────────────
# SynaptiQ — variables d'environnement (copier en .env)
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ─── Base de données PostgreSQL ───
# En local (hors Docker) : port hôte 5435 exposé par docker-compose.
DATABASE_URL=postgresql://synaptiq:synaptiq_password@127.0.0.1:5435/synaptiq_db
# En conteneur, docker-compose surcharge automatiquement avec :
#   postgresql://synaptiq:synaptiq_password@postgres:5432/synaptiq_db

# ─── Cache & file d'événements Redis ───
REDIS_URL=redis://127.0.0.1:6399/0
# En conteneur : redis://redis:6379/0 (surchargé par docker-compose)

# ─── Embeddings (Phase 1) ───
# Fournisseur : lmstudio (défaut) | openai | mock (tests uniquement)
EMBEDDING_PROVIDER=lmstudio
# Endpoint OpenAI-compatible de LM Studio (le serveur local doit tourner, modèle chargé).
#   En local          : http://localhost:1234/v1
#   En conteneur      : http://host.docker.internal:1234/v1 (surchargé par docker-compose)
EMBEDDING_BASE_URL=http://localhost:1234/v1
# Identifiant du modèle chargé dans LM Studio (adapter au nom exact affiché par LM Studio,
# visible via  curl http://localhost:1234/v1/models ).
EMBEDDING_MODEL=text-embedding-all-minilm-l6-v2-embedding
# Dimension du vecteur — DOIT correspondre à la colonne VECTOR(n) en base (384 par défaut).
EMBEDDING_DIM=384
# Clé API de l'endpoint embeddings — LM Studio l'ignore, mettre une valeur factice.
EMBEDDING_API_KEY=lm-studio

# ─── Extraction LLM (worker de consolidation) ───
# Fournisseur : mock (heuristique locale, aucun appel réseau) | openrouter
LLM_PROVIDER=mock
LLM_API_KEY=your_api_key_here
LLM_MODEL=meta-llama/llama-3-8b-instruct:free

# ─── Sécurité ───
# Tenant de CETTE instance (SynaptiQ est auto-hébergé : un déploiement = un tenant).
# Injecté côté serveur ; jamais transmis par l'agent. La séparation par agent se
# fait via `agent_id` dans les appels. Ne changer que si des données existent déjà
# sous un autre identifiant en base.
SYNAPTIQ_TENANT=default
#
# Exiger une clé API (header Bearer) sur chaque requête.
#   false (défaut) = instance de confiance (localhost / réseau interne).
#   IMPORTANT : si l'API est exposée sur Internet, mettre true et créer une clé
#   (scripts/create_api_key.py), sinon l'instance est ouverte en lecture/écriture.
SYNAPTIQ_AUTH_REQUIRED=false
#
# Origines CORS pour un front NAVIGATEUR (séparées par des virgules).
#   Vide (défaut) = aucune origine navigateur (API appelée serveur-à-serveur : OK).
#   Lister les origines explicites (ex: https://app.exemple.com) si front web.
#   '*' est toléré mais désactive automatiquement les credentials (non conforme).
CORS_ORIGINS=
# Rate limiting global (format slowapi, ex: 120/minute, 5/second).
RATE_LIMIT=120/minute
# Pool de connexions PostgreSQL (API).
DB_POOL_MIN=1
DB_POOL_MAX=10
# Seuil de similarité pour l'archivage des préférences contradictoires (0..1).
CONTRADICTION_SIM_THRESHOLD=0.8

# ─── SDK / MCP ───
SYNAPTIQ_API_URL=http://127.0.0.1:8000
# Clé API SynaptiQ utilisée par le SDK et le serveur MCP (créée via scripts/create_api_key.py).
SYNAPTIQ_API_KEY=

# ─── Serveur MCP ───
# Transport : stdio (défaut, pour Claude Desktop / Cursor) | sse | streamable-http
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8765
